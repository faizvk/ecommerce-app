# Leave VITE_BASE_URL empty for local dev — Vite proxies /api → localhost:5000
# Set it to your deployed backend URL when deploying the frontend separately
# e.g. VITE_BASE_URL=https://your-backend.onrender.com
VITE_BASE_URL=

VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id
VITE_CLOUDINARY_UPLOAD_URL=https://api.cloudinary.com/v1_1/<your_cloud_name>/image/upload
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset
