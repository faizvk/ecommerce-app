# ── Docker Compose environment variables ─────────────────────────────────────
# Copy this file to .env and fill in your values before running:
#   docker compose up --build

# ── Database ─────────────────────────────────────────────────────────────────
# Default uses the bundled MongoDB service.
# Replace with your Atlas URI to use MongoDB Atlas instead:
MONGOOSE_URI=mongodb://mongo:27017/ecommerce

# ── Redis ─────────────────────────────────────────────────────────────────────
# Default uses the bundled Redis service. Remove / leave blank to disable cache.
REDIS_URL=redis://redis:6379

# ── JWT secrets (REQUIRED — use long random strings) ──────────────────────────
ACCESS_SECRET_KEY=change_me_access_secret_min_32_chars
REFRESH_SECRET_KEY=change_me_refresh_secret_min_32_chars

# ── CORS (the public URL of the frontend) ─────────────────────────────────────
CLIENT_URL=http://localhost

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_oauth_client_id
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id

# ── Razorpay ─────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ── Nodemailer / SMTP (optional — password reset emails) ─────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=MyStore <your_email@gmail.com>

# ── Cloudinary (frontend image uploads) ──────────────────────────────────────
VITE_CLOUDINARY_UPLOAD_URL=https://api.cloudinary.com/v1_1/<your_cloud_name>/image/upload
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset
