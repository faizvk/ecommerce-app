{
  "name": "ecommerce-backend",
  "version": "1.0.0",
  "description": "NexKart backend — Express + Mongoose API",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "seed": "node scripts/seedProducts.js",
    "lint": "eslint . --ext .js --ignore-pattern node_modules",
    "lint:fix": "eslint . --ext .js --ignore-pattern node_modules --fix",
    "format": "prettier --write \"**/*.{js,json,md}\" --ignore-path ../.prettierignore",
    "format:check": "prettier --check \"**/*.{js,json,md}\" --ignore-path ../.prettierignore",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "ecommerce",
    "express",
    "mongoose",
    "razorpay"
  ],
  "author": "faiz",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "google-auth-library": "^10.5.0",
    "groq-sdk": "^1.1.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^9.0.0",
    "nodemailer": "^8.0.5",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "razorpay": "^2.9.6",
    "redis": "^5.10.0",
    "uuid": "^11.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "nodemon": "^3.1.11",
    "pino-pretty": "^11.3.0",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "vitest": "^2.1.8"
  }
}
